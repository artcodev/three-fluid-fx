{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": false,
    "removeComments": false,
    "sourceMap": false,
    "target": "ES2020",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "noEmitOnError": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "outDir": "examples-js",
    "rootDir": "examples",
    "paths": {}
  },
  "include": ["examples"]
}
