---
const gaId = import.meta.env.PUBLIC_GA_ID
const enabled = import.meta.env.VERCEL_ENV === 'production' && Boolean(gaId)
const gaSrc = enabled ? `https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(gaId)}` : undefined
const gaScript = enabled
  ? `
    window.dataLayer = window.dataLayer || [];
    window.gtag = window.gtag || function gtag(){window.dataLayer.push(arguments);}
    window.gtag('js', new Date());
    window.gtag('config', ${JSON.stringify(gaId)});
  `
  : undefined
---

{
  enabled && (
    <>
      <script is:inline async src={gaSrc} />
      <script is:inline set:html={gaScript} />
    </>
  )
}
