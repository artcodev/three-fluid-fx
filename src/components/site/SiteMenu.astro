---
import type { ExampleEntry } from '../../data/examples'
import { exampleGroups, examples } from '../../data/examples'

interface Props {
  active?: 'examples' | 'tutorials'
  currentExample?: ExampleEntry
}

const { active, currentExample } = Astro.props

const guideLinks = [
  { href: '/tutorials/getting-started/', label: 'Getting Started' },
  { href: '/tutorials/effects-guide/', label: 'Effects Guide' },
  { href: '/tutorials/particles-guide/', label: 'Particles Guide' },
  { href: '/tutorials/glsl-vs-tsl/', label: 'GLSL vs TSL' },
]

const exampleSections = exampleGroups.map((group) => ({
  ...group,
  current: currentExample?.engine === group.engine && currentExample?.level === group.level,
  items: examples
    .filter((example) => example.engine === group.engine && example.level === group.level)
    .sort((a, b) => a.order - b.order),
}))

const isExamplesHome = active === 'examples' && !currentExample
const isTutorialsHome = active === 'tutorials'
---

<button
  class="site-menu-trigger"
  type="button"
  aria-haspopup="dialog"
  aria-controls="site-menu-drawer"
  aria-expanded="false"
  data-site-menu-open
>
  <span class="site-menu-icon" aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
  </span>
  <span>Menu</span>
</button>

<dialog class="site-menu-dialog" id="site-menu-drawer" aria-label="Site menu" data-site-menu>
  <div class="site-menu-surface">
    <header class="site-menu-head">
      <a href="/" class="site-menu-brand">
        <span>three-fluid-fx</span>
        <strong>Cursor-driven fluid effects for three.js</strong>
      </a>
      <button class="site-menu-close" type="button" aria-label="Close menu" data-site-menu-close>
        ×
      </button>
    </header>

    <nav class="site-menu-content" aria-label="Site menu navigation">
      <section class="site-menu-section">
        <h2>Start</h2>
        <div class="site-menu-links">
          <a
            class:list={[isExamplesHome && 'is-active']}
            href="/"
            aria-current={isExamplesHome ? 'page' : undefined}
          >
            Examples
          </a>
          <a
            class:list={[isTutorialsHome && 'is-active']}
            href="/tutorials/"
            aria-current={isTutorialsHome ? 'page' : undefined}
          >
            Tutorials
          </a>
        </div>
      </section>

      <section class="site-menu-section">
        <h2>Guides</h2>
        <div class="site-menu-links">
          {guideLinks.map((link) => <a href={link.href}>{link.label}</a>)}
        </div>
      </section>

      <section class="site-menu-section">
        <h2>Examples</h2>
        <div class="site-menu-groups">
          {
            exampleSections.map((group) => (
              <details class="site-menu-group" open={group.current || undefined}>
                <summary class:list={[group.current && 'is-current']}>{group.label}</summary>
                <div class="site-menu-links site-menu-links--compact">
                  {group.items.map((item) => (
                    <a
                      class:list={[currentExample?.slug === item.slug && 'is-active']}
                      aria-current={currentExample?.slug === item.slug ? 'page' : undefined}
                      href={`/examples/${item.slug}/`}
                    >
                      {item.shortTitle}
                    </a>
                  ))}
                </div>
              </details>
            ))
          }
        </div>
      </section>

    </nav>

    <footer class="site-menu-footer" aria-label="External links">
      <div class="site-menu-icon-links">
        <a href="https://github.com/artcodev/three-fluid-fx" aria-label="GitHub">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2C6.48 2 2 6.58 2 12.24c0 4.52 2.86 8.35 6.84 9.71.5.09.68-.22.68-.49v-1.92c-2.78.62-3.37-1.22-3.37-1.22-.45-1.19-1.11-1.5-1.11-1.5-.91-.64.07-.63.07-.63 1 .07 1.53 1.06 1.53 1.06.9 1.56 2.35 1.11 2.92.85.09-.66.35-1.11.63-1.36-2.22-.26-4.55-1.14-4.55-5.05 0-1.12.39-2.03 1.03-2.74-.1-.26-.45-1.3.1-2.7 0 0 .84-.28 2.75 1.05A9.35 9.35 0 0 1 12 5.96c.85 0 1.7.12 2.5.35 1.9-1.33 2.74-1.05 2.74-1.05.55 1.4.2 2.44.1 2.7.64.71 1.03 1.62 1.03 2.74 0 3.93-2.34 4.79-4.57 5.04.36.32.68.94.68 1.9v2.82c0 .27.18.59.69.49A10.14 10.14 0 0 0 22 12.24C22 6.58 17.52 2 12 2Z" />
          </svg>
        </a>
        <a href="https://www.npmjs.com/package/three-fluid-fx" aria-label="npm">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 7h18v10H3V7Zm3 8h2V9h8v6h2V9h1v6h1V8H4v7h1V9h1v6Zm4 0h2v-4h2v4h1V10h-5v5Z" />
          </svg>
        </a>
        <a href="https://x.com/artcreativecode" aria-label="X">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M13.86 10.47 21.12 2h-1.72l-6.3 7.35L8.06 2H2.25l7.61 11.08L2.25 22h1.72l6.65-7.77L15.94 22h5.81l-7.89-11.53Zm-2.35 2.74-.77-1.1L4.6 3.29h2.63l4.95 7.1.77 1.1 6.45 9.26h-2.63l-5.26-7.54Z" />
          </svg>
        </a>
        <a href="https://experiments.artcreativecode.com" aria-label="Experiments">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M9 3.5h6v1.7l-1.35.9v3.18l5.17 7.8A2.2 2.2 0 0 1 16.98 20.5H7.02a2.2 2.2 0 0 1-1.84-3.42l5.17-7.8V6.1L9 5.2V3.5Zm3.15 6.85-2.02 3.06h3.74l-2.02-3.06V5.65h.3v4.7Zm-3.2 4.86-2.28 3.43a.42.42 0 0 0 .35.65h9.96a.42.42 0 0 0 .35-.65l-2.28-3.43h-6.1Z" />
          </svg>
        </a>
      </div>
    </footer>
  </div>
</dialog>

<script>
  const dialog = document.querySelector('[data-site-menu]')
  const openButton = document.querySelector('[data-site-menu-open]')
  const closeButton = document.querySelector('[data-site-menu-close]')

  if (dialog instanceof HTMLDialogElement && openButton instanceof HTMLButtonElement) {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    const closeDelay = prefersReducedMotion ? 0 : 260

    const syncExpandedState = () => {
      openButton.setAttribute('aria-expanded', String(dialog.open))
    }

    const openMenu = () => {
      if (!dialog.open) dialog.showModal()
      dialog.classList.remove('is-closing')
      requestAnimationFrame(() => {
        dialog.classList.add('is-open')
        syncExpandedState()
      })
    }

    const closeMenu = () => {
      if (!dialog.open || dialog.classList.contains('is-closing')) return
      dialog.classList.remove('is-open')
      dialog.classList.add('is-closing')
      openButton.setAttribute('aria-expanded', 'false')
      window.setTimeout(() => {
        if (dialog.classList.contains('is-closing')) dialog.close()
      }, closeDelay)
    }

    openButton.addEventListener('click', openMenu)

    closeButton?.addEventListener('click', closeMenu)
    dialog.addEventListener('cancel', (event) => {
      event.preventDefault()
      closeMenu()
    })
    dialog.addEventListener('close', () => {
      dialog.classList.remove('is-open', 'is-closing')
      syncExpandedState()
    })
    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) closeMenu()
    })
  }
</script>
